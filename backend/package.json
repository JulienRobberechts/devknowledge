{
  "name": "devknowledge-backend",
  "version": "1.0.3",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -r src/infrastructure/db/migrations dist/infrastructure/db/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/infrastructure/db/migrate.ts",
    "migrate:prod": "node dist/infrastructure/db/migrate.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-rate-limit": "^5.1.3",
    "@types/pino-pretty": "^4.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "marked": "^18.0.5",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
