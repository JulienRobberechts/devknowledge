# ─── Api ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# ALLOWED_ORIGIN: dev=http://localhost:5173, prod=https://argos-frontend-production.up.railway.app
ALLOWED_ORIGIN=http://localhost:5173

# ─── Storage ───────────────────────────────────────────────────────────────────
# DEFAULT_STORAGE_BACKEND: 'local' | 'r2'  (default: local)
DEFAULT_STORAGE_BACKEND=local

# UPLOAD_DIR=/app/uploads

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://argos:PwdXXX@localhost:5432/argos
POSTGRES_PASSWORD=PwdXXX

# ─── Auth ──────────────────────────────────────────────────────────────────────
APP_PASSWORD=dev-secret-key-change-in-prod

# ─── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

