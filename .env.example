# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# UPLOAD_DIR=/app/uploads
# ALLOWED_ORIGIN: dev=http://localhost:5173, prod=https://argos-frontend-production.up.railway.app
ALLOWED_ORIGIN=http://localhost:5173

# ─── Storage ───────────────────────────────────────────────────────────────────
# DEFAULT_STORAGE_BACKEND: 'local' | 'r2'  (default: local)
DEFAULT_STORAGE_BACKEND=local
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devknowledge:devknowledge@localhost:5432/devknowledge
POSTGRES_PASSWORD=devknowledge

# ─── Auth ──────────────────────────────────────────────────────────────────────
APP_PASSWORD=dev-secret-key-change-in-prod

# ─── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ─── RAG — Chunking ────────────────────────────────────────────────────────────
# DEFAULT_CHUNKING_STRATEGY: 'sentence' | 'recursive'
DEFAULT_CHUNKING_STRATEGY=sentence
DEFAULT_CHUNK_SIZE_TOKENS=128
DEFAULT_CHUNK_OVERLAP_TOKENS=32

# ─── RAG — Reranking ───────────────────────────────────────────────────────────
# RERANK_ENABLED: true | false (default: true)
DEFAULT_RERANK_MODEL=rerank-2.5
# DEFAULT_RERANK_CANDIDATE_MULTIPLIER=3

# ─── RAG — Retrieval ───────────────────────────────────────────────────────────
DEFAULT_RETRIEVAL_LIMIT=5
DEFAULT_RETRIEVAL_MIN_SCORE=0.35

# ─── LLM ───────────────────────────────────────────────────────────────────────
DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001
DEFAULT_LLM_MAX_TOKENS=1024
DEFAULT_LLM_TEMPERATURE=0.1
